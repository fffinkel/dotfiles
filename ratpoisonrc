startup_message off
escape C-space

exec xcompmgr -c -f -D 5 &
exec nitrogen --restore
exec ~/.dropbox-dist/dropboxd

exec xsetroot -cursor_name left_ptr
exec xmodmap -quiet ~/.Xmodmap

set fgcolor #FFFFFF
set bgcolor #000000
set font -*-terminus-medium-r-normal-*-14-*-*-*-*-*-*-*
set waitcursor 1
set border 2
set inputwidth 1200

set winname class
set winfmt %n %s %t
set winliststyle column
set wingravity center
set transgravity center

set bargravity sw
set barpadding 1 1
set barborder 1
